{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER,1433;Database=PastisserieDB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_SECRET_KEY_MINIMUM_32_CHARACTERS_REQUIRED_FOR_SECURITY",
    "Issuer": "PastisserieAPI",
    "Audience": "PastisserieClients",
    "ExpirationMinutes": 60
  },
  "ApiUrl": "http://localhost:5000",
  "FrontendUrl": "http://localhost:5173",
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "User": "YOUR_EMAIL@gmail.com",
    "Password": "YOUR_GMAIL_APP_PASSWORD",
    "EnableSsl": true,
    "From": "YOUR_EMAIL@gmail.com",
    "FromName": "Pâtisserie Deluxe"
  }
}
